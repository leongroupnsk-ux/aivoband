# Доставка заявок в Telegram (ТЗ §9).
# 1. Создать бота у @BotFather → токен.
# 2. Добавить бота в рабочий чат/группу, узнать chat_id (например, через @userinfobot).
# Без этих переменных заявки логируются на сервере и не теряются.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Базовый URL сайта (canonical, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://aivo.example

# Аналитика (вшивается при сборке; без них счётчики не подключаются).
# NEXT_PUBLIC_YM_ID — номер счётчика Яндекс.Метрики (только цифры).
# NEXT_PUBLIC_GA_ID — Measurement ID GA4 (вида G-XXXXXXX).
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# Админка /admin
# ADMIN_PASSWORD — пароль входа менеджера (придумать надёжный).
# ADMIN_SECRET — секрет подписи сессии, случайная строка (openssl rand -hex 32).
ADMIN_PASSWORD=
ADMIN_SECRET=
